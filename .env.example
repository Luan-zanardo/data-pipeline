# =============================================================================
# Configuração da Etapa 3 — copie para `.env` e preencha.
#   cp .env.example .env
# O arquivo .env NÃO deve ser commitado (está no .gitignore).
# =============================================================================

# ---- Banco de ORIGEM (de onde a ingestão lê os dados) -----------------------
# Os valores abaixo apontam para o Postgres de origem usado pelo projeto.
# Substitua se o banco mudar.
SOURCE_DB_HOST=db.wutleihrwkhcfevexdcj.supabase.co
SOURCE_DB_PORT=5432
SOURCE_DB_NAME=postgres
SOURCE_DB_USER=teammate
SOURCE_DB_PASSWORD=coloque_a_senha_aqui
SOURCE_DB_SSLMODE=require

# ---- Banco de DESTINO (Gold virtualizada — data source do Metabase) ---------
# Preencha com o Postgres online que recebera as tabelas Gold via JDBC.
# É também o banco que o Metabase consome como data source na Etapa 6.
DEST_DB_HOST=coloque_o_host_aqui
DEST_DB_PORT=5432
DEST_DB_NAME=postgres
DEST_DB_USER=coloque_o_usuario_aqui
DEST_DB_PASSWORD=coloque_a_senha_aqui
DEST_DB_SSLMODE=require

# ---- MinIO / Object storage do Data Lake ------------------------------------
# Credenciais do MinIO. Em dev pode manter os defaults; em produção troque.
# Console web do MinIO: http://localhost:9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Destino da camada Landing. s3://datalake/landing grava no MinIO (default).
# Para gravar em disco local, use um caminho sem esquema, ex.: datalake/landing
LANDING_PATH=s3://datalake/landing
# Endpoint S3 do MinIO (interno do Docker). Rodando fora do Docker, use
# http://localhost:9000. Para a AWS S3 de verdade, deixe vazio/remova.
S3_ENDPOINT_URL=http://minio:9000

# ---- Credenciais da UI do Airflow (http://localhost:8080) -------------------
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# ---- Metabase self-host (Etapa 6 — http://localhost:3000) -------------------
# Banco de aplicação do Metabase (guarda dashboards/usuários). Em dev pode
# manter os defaults; em produção troque a senha. O data source com os dados
# (Gold) é o banco de DESTINO acima (DEST_DB_*), conectado pelo metabase-init.
MB_DB_NAME=metabase
MB_DB_USER=metabase
MB_DB_PASSWORD=metabase

# ---- Admin inicial do Metabase (provisionado automaticamente pelo init) -----
# O metabase-init cria este usuario admin no primeiro acesso e ja conecta o
# data source (DEST_DB_*) e o dashboard. A senha precisa ter complexidade minima.
MB_ADMIN_EMAIL=admin@example.com
MB_ADMIN_PASSWORD=metabaseadmin1

# ---- UID para permissões dos volumes (Linux/Mac). No Windows pode ignorar. --
AIRFLOW_UID=50000
